generator client {`n  binaryTargets = ["native", "debian-openssl-3.0.x"]
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  WAREHOUSE
  SALES
  VIEWER
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  role          Role      @default(VIEWER)
  isActive      Boolean   @default(true)
  avatar        String?
  phone         String?
  lastLogin     DateTime?
  refreshToken  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  salesOrders      SaleOrder[]
  purchaseOrders   PurchaseOrder[]
  inventoryMoves   InventoryMovement[]
  auditLogs        AuditLog[]
  productionOrders ProductionOrder[]
  alerts           AlertNotification[]
  quotes           Quote[]

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────
// PRODUCTS & CATEGORIES
// ─────────────────────────────────────────────

model AluminumSector {
  id          String         @id @default(uuid())
  name        String         @unique
  emoji       String         @default("🔩")
  description String?
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  types       AluminumType[]
  products    Product[]

  @@map("aluminum_sectors")
}

model AluminumType {
  id          String         @id @default(uuid())
  name        String
  sectorId    String
  sector      AluminumSector @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  description String?
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  products    Product[]

  @@unique([name, sectorId])
  @@index([sectorId])
  @@map("aluminum_types")
}

model AluminumSeries {
  id             String    @id @default(uuid())
  code           String    @unique  // "1000", "2000", etc.
  name           String    @unique  // "Serie 1000 - Aluminio Puro"
  principalAlloy String?            // "Aluminio puro (≥99%)"
  description    String?
  applications   String?
  isActive       Boolean   @default(true)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  products       Product[]

  @@map("aluminum_series")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  color       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("categories")
}

enum ProductUnit {
  KG
  TON
  METER
  PIECE
  BOX
  ROLL
  SHEET
  BAR
  TUBE
  PROFILE
}

model Product {
  id              String      @id @default(uuid())
  code            String      @unique
  barcode         String?     @unique
  name            String
  description     String?
  categoryId      String
  category        Category    @relation(fields: [categoryId], references: [id])
  unit            ProductUnit @default(KG)
  weight          Decimal?    @db.Decimal(10, 3)
  thickness       Decimal?    @db.Decimal(10, 3)
  width           Decimal?    @db.Decimal(10, 3)
  length          Decimal?    @db.Decimal(10, 3)
  costPrice       Decimal     @default(0) @db.Decimal(12, 4)
  salePrice       Decimal     @default(0) @db.Decimal(12, 4)
  minStock        Decimal     @default(0) @db.Decimal(12, 3)
  maxStock        Decimal     @default(0) @db.Decimal(12, 3)
  currentStock    Decimal     @default(0) @db.Decimal(12, 3)
  image           String?
  isActive        Boolean     @default(true)
  isAluminum      Boolean     @default(true)
  sectorId        String?
  sector          AluminumSector? @relation(fields: [sectorId], references: [id])
  aluminumTypeId  String?
  aluminumType    AluminumType?   @relation(fields: [aluminumTypeId], references: [id])
  seriesId        String?
  series          AluminumSeries? @relation(fields: [seriesId], references: [id])
  alloyType       String?
  temper          String?
  // ── CFDI ──
  contadigitalIdProducto Int?  // ID producto en ContaDigital
  contadigitalIdUm       Int?  // ID unidad de medida en ContaDigital
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  inventoryItems     InventoryItem[]
  inventoryMovements InventoryMovement[]
  purchaseItems      PurchaseOrderItem[]
  saleItems          SaleOrderItem[]
  kardex             Kardex[]
  productionInputs   ProductionInput[]
  productionOutputs  ProductionOutput[]
  alerts             Alert[]
  quoteItems         QuoteItem[]

  @@index([code])
  @@index([categoryId])
  @@map("products")
}

// ─────────────────────────────────────────────
// WAREHOUSES & INVENTORY
// ─────────────────────────────────────────────

model Warehouse {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  address     String?
  isActive    Boolean   @default(true)
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  inventoryItems     InventoryItem[]
  inventoryMovements InventoryMovement[]
  fromMovements      InventoryMovement[] @relation("fromWarehouse")
  toMovements        InventoryMovement[] @relation("toWarehouse")

  @@map("warehouses")
}

model InventoryItem {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Decimal   @default(0) @db.Decimal(12, 3)
  lotNumber   String?
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@map("inventory_items")
}

enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  TRANSFER
  PRODUCTION_IN
  PRODUCTION_OUT
  RETURN
}

model InventoryMovement {
  id              String        @id @default(uuid())
  type            MovementType
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  warehouseId     String
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id])
  fromWarehouseId String?
  fromWarehouse   Warehouse?    @relation("fromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse?    @relation("toWarehouse", fields: [toWarehouseId], references: [id])
  quantity        Decimal       @db.Decimal(12, 3)
  unitCost        Decimal?      @db.Decimal(12, 4)
  totalCost       Decimal?      @db.Decimal(12, 4)
  previousStock   Decimal       @db.Decimal(12, 3)
  currentStock    Decimal       @db.Decimal(12, 3)
  referenceType   String?
  referenceId     String?
  notes           String?
  lotNumber       String?
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  createdAt       DateTime      @default(now())

  kardex          Kardex?

  @@index([productId])
  @@index([warehouseId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_movements")
}

model Kardex {
  id          String            @id @default(uuid())
  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  movementId  String            @unique
  movement    InventoryMovement @relation(fields: [movementId], references: [id])
  date        DateTime          @default(now())
  entryQty    Decimal?          @db.Decimal(12, 3)
  exitQty     Decimal?          @db.Decimal(12, 3)
  adjustQty   Decimal?          @db.Decimal(12, 3)
  balance     Decimal           @db.Decimal(12, 3)
  unitCost    Decimal           @db.Decimal(12, 4)
  totalValue  Decimal           @db.Decimal(14, 4)
  description String?

  @@index([productId])
  @@index([date])
  @@map("kardex")
}

// ─────────────────────────────────────────────
// SUPPLIERS
// ─────────────────────────────────────────────

model Supplier {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  rfc           String?
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String    @default("México")
  contactName   String?
  paymentTerms  Int       @default(30)
  isActive      Boolean   @default(true)
  rating        Int       @default(5)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([code])
  @@map("suppliers")
}

// ─────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────

model Customer {
  id               String    @id @default(uuid())
  code             String    @unique
  name             String
  rfc              String?
  email            String?
  phone            String?
  address          String?
  city             String?
  country          String    @default("México")
  contactName      String?
  creditLimit      Decimal   @default(0) @db.Decimal(12, 2)
  creditUsed       Decimal   @default(0) @db.Decimal(12, 2)
  paymentTerms     Int       @default(0)
  priceLevel       Int       @default(1)
  isActive         Boolean   @default(true)
  notes            String?
  // ── CFDI 4.0 ──
  zipCode          String?   // CP domicilio fiscal del receptor
  regimenFiscal    String?   // Cód. SAT régimen fiscal (ej: "601", "616")
  usoCfdiDefault   String?   @default("G01")
  contadigitalId   Int?      // ID cliente en ContaDigital (auto-sync)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  saleOrders    SaleOrder[]
  quotes        Quote[]

  @@index([code])
  @@map("customers")
}

// ─────────────────────────────────────────────
// PURCHASES
// ─────────────────────────────────────────────

enum PurchaseStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id              String          @id @default(uuid())
  folio           String          @unique
  supplierId      String
  supplier        Supplier        @relation(fields: [supplierId], references: [id])
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  status          PurchaseStatus  @default(DRAFT)
  orderDate       DateTime        @default(now())
  expectedDate    DateTime?
  receivedDate    DateTime?
  subtotal        Decimal         @default(0) @db.Decimal(12, 2)
  tax             Decimal         @default(0) @db.Decimal(12, 2)
  total           Decimal         @default(0) @db.Decimal(12, 2)
  currency        String          @default("MXN")
  exchangeRate    Decimal         @default(1) @db.Decimal(10, 4)
  notes           String?
  attachments     String[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items           PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  orderedQty      Decimal       @db.Decimal(12, 3)
  receivedQty     Decimal       @default(0) @db.Decimal(12, 3)
  unitCost        Decimal       @db.Decimal(12, 4)
  subtotal        Decimal       @db.Decimal(12, 2)
  lotNumber       String?
  notes           String?

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// ─────────────────────────────────────────────
// SALES
// ─────────────────────────────────────────────

enum SaleStatus {
  DRAFT
  CONFIRMED
  PARTIAL
  DELIVERED
  INVOICED
  CANCELLED
}

model SaleOrder {
  id           String      @id @default(uuid())
  folio        String      @unique
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  status       SaleStatus  @default(DRAFT)
  saleDate     DateTime    @default(now())
  deliveryDate DateTime?
  subtotal     Decimal     @default(0) @db.Decimal(12, 2)
  discount     Decimal     @default(0) @db.Decimal(12, 2)
  tax          Decimal     @default(0) @db.Decimal(12, 2)
  total        Decimal     @default(0) @db.Decimal(12, 2)
  currency     String      @default("MXN")
  exchangeRate Decimal     @default(1) @db.Decimal(10, 4)
  notes        String?
  invoiceNo    String?
  // ── CFDI ──
  cfdiId          Int?      // ID factura en ContaDigital
  cfdiUuid        String?   // UUID / Folio Fiscal SAT
  cfdiSerie       String?
  cfdiStatus      String?   // VIGENTE | CANCELADO
  cfdiXmlUrl      String?
  cfdiPdfUrl      String?
  cfdiCancelledAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items        SaleOrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([saleDate])
  @@map("sale_orders")
}

model SaleOrderItem {
  id          String    @id @default(uuid())
  saleOrderId String
  saleOrder   SaleOrder @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Decimal   @db.Decimal(12, 3)
  unitPrice   Decimal   @db.Decimal(12, 4)
  discount    Decimal   @default(0) @db.Decimal(5, 2)
  subtotal    Decimal   @db.Decimal(12, 2)
  deliveredQty Decimal  @default(0) @db.Decimal(12, 3)
  notes       String?
  cuts        Json?

  @@index([saleOrderId])
  @@index([productId])
  @@map("sale_order_items")
}

// ─────────────────────────────────────────────
// QUOTES / COTIZACIONES
// ─────────────────────────────────────────────

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

model Quote {
  id           String      @id @default(uuid())
  folio        String      @unique
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  status       QuoteStatus @default(DRAFT)
  validUntil   DateTime?
  notes        String?
  currency     String      @default("MXN")
  exchangeRate Decimal     @default(1) @db.Decimal(12, 4)
  subtotal     Decimal     @default(0) @db.Decimal(14, 2)
  discount     Decimal     @default(0) @db.Decimal(14, 2)
  tax          Decimal     @default(0) @db.Decimal(14, 2)
  total        Decimal     @default(0) @db.Decimal(14, 2)
  saleOrderId  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items        QuoteItem[]

  @@index([customerId])
  @@index([status])
  @@map("quotes")
}

model QuoteItem {
  id        String   @id @default(uuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Decimal  @db.Decimal(12, 3)
  unitPrice Decimal  @db.Decimal(12, 4)
  discount  Decimal  @default(0) @db.Decimal(5, 2)
  subtotal  Decimal  @db.Decimal(14, 2)
  notes     String?
  createdAt DateTime @default(now())

  @@index([quoteId])
  @@map("quote_items")
}

// ─────────────────────────────────────────────
// PRODUCTION
// ─────────────────────────────────────────────

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionOrder {
  id          String           @id @default(uuid())
  folio       String           @unique
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  status      ProductionStatus @default(PLANNED)
  description String?
  startDate   DateTime?
  endDate     DateTime?
  scrapRate   Decimal          @default(0) @db.Decimal(5, 2)
  totalScrap  Decimal          @default(0) @db.Decimal(12, 3)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  inputs      ProductionInput[]
  outputs     ProductionOutput[]

  @@index([status])
  @@map("production_orders")
}

model ProductionInput {
  id                String          @id @default(uuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  plannedQty        Decimal         @db.Decimal(12, 3)
  consumedQty       Decimal         @default(0) @db.Decimal(12, 3)
  unitCost          Decimal         @db.Decimal(12, 4)

  @@index([productionOrderId])
  @@map("production_inputs")
}

model ProductionOutput {
  id                String          @id @default(uuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  plannedQty        Decimal         @db.Decimal(12, 3)
  producedQty       Decimal         @default(0) @db.Decimal(12, 3)
  scrapQty          Decimal         @default(0) @db.Decimal(12, 3)
  cuts              Json?

  @@index([productionOrderId])
  @@map("production_outputs")
}

// ─────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────

enum AlertType {
  LOW_STOCK
  OVER_STOCK
  NO_MOVEMENT
  PURCHASE_PENDING
  SALE_PENDING
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Alert {
  id          String        @id @default(uuid())
  type        AlertType
  severity    AlertSeverity @default(WARNING)
  productId   String?
  product     Product?      @relation(fields: [productId], references: [id])
  title       String
  message     String
  isActive    Boolean       @default(true)
  threshold   Decimal?      @db.Decimal(12, 3)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  notifications AlertNotification[]

  @@index([type])
  @@index([isActive])
  @@map("alerts")
}

model AlertNotification {
  id        String   @id @default(uuid())
  alertId   String
  alert     Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([alertId])
  @@map("alert_notifications")
}

// ─────────────────────────────────────────────
// CFDI / FACTURACIÓN ELECTRÓNICA
// ─────────────────────────────────────────────

model CfdiConfig {
  id                  String   @id @default(uuid())
  // ContaDigital connection
  idEmpresa           Int      @default(0)
  apiKey              String   @default("")
  baseUrl             String   @default("https://app.contadigital.mx/dev/pruebas")
  // Datos del emisor en ContaDigital
  idRfc               Int      @default(0)
  idSerie             Int      @default(0)
  idSucursal          Int      @default(0)
  idLugarExpedicion   Int      @default(0)
  lugarExpedicion     String   @default("")   // CP lugar de expedición
  // Catálogos de moneda y forma de pago
  idMoneda            Int      @default(1)    // MXN
  idFormaPago03       Int      @default(0)    // Transferencia electrónica
  idFormaPago04       Int      @default(0)    // Tarjeta de crédito
  idFormaPago01       Int      @default(0)    // Efectivo
  idFormaPago99       Int      @default(0)    // Por definir
  // Catálogos de unidades de medida (mapeadas desde ProductUnit)
  idUmKg              Int      @default(0)
  idUmTon             Int      @default(0)
  idUmMetro           Int      @default(0)
  idUmPieza           Int      @default(0)
  idUmRollo           Int      @default(0)
  idUmLamina          Int      @default(0)
  idUmBarra           Int      @default(0)
  idUmTubo            Int      @default(0)
  idUmPerfil          Int      @default(0)
  idUmCaja            Int      @default(0)
  // Producto genérico de respaldo
  idProductoDefault   Int      @default(0)
  // Estado
  isConfigured        Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("cfdi_config")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
